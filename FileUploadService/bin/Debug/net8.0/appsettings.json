{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=file_upload_db;Username=postgres;Password=root"
  },
  "FileStorage": {
    "BasePath": "C:\\Users\\harsh.gupta\\Documents\\uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp", ".pdf", ".docx", ".xlsx" ],
    "AllowedMimeTypes": {
      ".jpg": "image/jpeg",
      ".jpeg": "image/jpeg",
      ".png": "image/png",
